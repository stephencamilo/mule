extends ../layouts/main

block content
  .flex.min-h-screen
    aside(class="w-64 bg-white border-r border-gray-200 p-4 hidden lg:block")
      h2(class="text-lg font-semibold text-gray-800 mb-4") Filters
      form(method="get" action=action class="space-y-3")
        each filter, name in filters
          div
            label(class="block text-sm font-medium text-gray-600 mb-1") #{filter.label}
            if filter.type === 'select'
              select(name=name class="w-full rounded-lg border-gray-200 shadow-sm focus:border-indigo-400 focus:ring focus:ring-indigo-200 text-sm")
                option(value="") All
                each label, val in filter.options
                  option(value=val selected=(filter.selected == val)) #{label}
            else if filter.type === 'number'
              input(type="number" name=name value=filter.selected step=filter.step || '1' class="w-full rounded-lg border-gray-200 shadow-sm focus:border-indigo-400 focus:ring focus:ring-indigo-200 text-sm")
            else
              input(type="text" name=name value=filter.selected class="w-full rounded-lg border-gray-200 shadow-sm focus:border-indigo-400 focus:ring focus:ring-indigo-200 text-sm")
        button(type="submit" class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 text-sm font-medium transition") Apply Filters

    main(class="flex-1 p-4 sm:p-6 lg:p-8 overflow-hidden")
      div(class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6")
        h1(class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight") #{entityKey.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
        a(href="/admin/" + entityKey + "/new" class="inline-flex items-center gap-1.5 bg-indigo-600 text-white px-4 py-2 rounded-lg shadow-sm hover:bg-indigo-700 hover:shadow transition-all duration-200 text-sm font-medium mt-3 sm:mt-0") ➕ New

      if items.length === 0
        div(class="bg-white rounded-xl border border-gray-100 p-8 text-center shadow-sm")
          span(class="text-4xl") 📭
          p(class="mt-2 text-base font-medium text-gray-500") No records found
          p(class="text-sm text-gray-400") ✨ Add your first entry to get started.
      else
        div(class="hidden md:flex items-center bg-white rounded-t-xl px-3 py-2 border-b border-gray-100 shadow-sm")
          each col in columns
            if fields[col]
              div(class="flex-1 px-2 text-xs font-semibold text-gray-400 uppercase tracking-wide") #{fields[col].label}
          div(class="w-24 text-right text-xs font-semibold text-gray-400 uppercase tracking-wide") Actions

        div(class="space-y-2")
          each item in items
            - var pk = Array.isArray(def.primaryKey) ? def.primaryKey : [def.primaryKey];
            - var idParts = pk.map(k => item[k]).filter(v => v != null);
            - var editUrl = '/admin/' + entityKey + '/edit/' + idParts.join('/');
            - var deleteUrl = '/admin/' + entityKey + '/delete/' + idParts.join('/');
            div(class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow transition-shadow duration-150")
              div(class="flex flex-col md:flex-row md:items-center gap-2 p-5 md:p-0")
                each col in columns
                  if fields[col]
                    div(class="flex flex-col md:flex-1 md:px-2")
                      span(class="text-xs font-medium text-gray-400 uppercase mb-0.5 md:hidden") #{fields[col].label}
                      span(class="text-sm text-gray-700 truncate md:whitespace-normal md:break-words")
                        if item._display && item._display[col] !== undefined
                          | #{item._display[col]}
                        else
                          | #{item[col]}
                div(class="flex items-center gap-1.5 md:ml-auto md:w-26 md:justify-end mt-1 md:mt-0 pt-1 md:pt-0 border-t md:border-t-0 border-gray-50")
                  a(href=editUrl title="Edit" class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 bg-indigo-50 hover:bg-indigo-100 px-2.5 py-1 rounded-md transition-colors text-xs font-medium") ✏️ Edit
                  a(href=deleteUrl onclick="return confirm('Are you sure you want to delete this record?')" title="Delete" class="inline-flex items-center gap-1 text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 px-2.5 py-1 rounded-md transition-colors text-xs font-medium") 🗑️ Delete