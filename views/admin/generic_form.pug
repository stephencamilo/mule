extends ../layouts/main

block content
  .min-h-screen(class="bg-gray-50/80 py-8 px-4")
    .max-w-2xl.mx-auto
      .bg-white.shadow-xl.rounded-2xl.overflow-hidden.border.border-gray-100

        .bg-gradient-to-r.from-indigo-600.to-indigo-700.px-6.py-5
          h1.text-2xl.font-bold.text-white.flex.items-center.gap-3
            span 📝
            if isEdit
              | Edit #{entityKey}
            else
              | Create #{entityKey}

        div(class="p-6 md:p-8")
          form(action=formUrl method="post" class="space-y-6")
            each field in formFields
              div
                label(class="block text-sm font-semibold text-gray-700 mb-1.5") #{field.label}
                != field.html

            .flex.flex-col(class="sm:flex-row justify-end gap-3 pt-4 border-t border-gray-100")
              a(href="/admin/" + entityKey class="inline-flex justify-center items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-colors duration-200 font-medium text-sm") ❌ Cancel
              button(type="submit" class="inline-flex justify-center items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 shadow-md hover:shadow-lg transition-all duration-200 font-medium text-sm") 💾 Save
