extends ../layouts/main

block content
  .min-h-screen(class="bg-gray-50/80 py-8 px-4")
    .max-w-lg.mx-auto
      .bg-white.shadow-xl.rounded-2xl.overflow-hidden.border.border-gray-100
        .bg-gradient-to-r.from-red-500.to-red-600.px-6.py-5
          h1.text-2xl.font-bold.text-white.flex.items-center.gap-3
            span ⚠️
            | Delete #{entityKey}

        .p-6(class="md:p-8 text-center")
          p.text-gray-600.mb-6 Are you sure you want to delete this record?
          form(action=deleteUrl method="post" class="flex justify-center gap-3")
            a(href="/admin/" + entityKey class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition-colors font-medium text-sm") ❌ Cancel
            button(type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-red-600 text-white rounded-xl hover:bg-red-700 shadow-md hover:shadow-lg transition-all font-medium text-sm") 🗑️ Confirm Delete
