- var locales = locals && locals.locales ? locals.locales : {}
- var currentLocale = locals && locals.currentLocale ? locals.currentLocale : 'en'
- var flagEmoji = locals && locals.flagEmoji ? locals.flagEmoji : {}
- var queryString = locals && locals.queryString ? locals.queryString : ''
- var links = locals && locals.links ? locals.links : []

nav(
  x-data="{ langOpen: false, mainOpen: false, mobileOpen: false }"
  class="bg-gradient-to-r from-white via-indigo-50/30 to-white shadow-md sticky top-0 z-50 border-b border-indigo-100 backdrop-blur-sm"
)
  .max-w-7xl.mx-auto.px-4(class="sm:px-6 lg:px-8")
    .flex.justify-between.h-16.items-center

      .flex.items-center.shrink-0
        a(
          href="/"
          class="group flex items-center space-x-2 font-extrabold text-2xl text-indigo-600 hover:text-indigo-500 transition-colors"
        )
          span.text-3xl(class="group-hover:scale-110 transition-transform duration-300") 🐾
          span.hidden(class="sm:inline") PetRecipes

      .hidden(class="md:flex items-center")
        .inline-flex.rounded-full.border.border-indigo-200(class="bg-white/80 shadow-sm backdrop-blur")

          .relative
            button(
              @click="langOpen = !langOpen"
              class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition-all rounded-l-full"
            )
              span 🌐 Lang
              span.text-xs.transition-transform.duration-200(:class="{ 'rotate-180': langOpen }") ▼

            .absolute.right-0.mt-3.w-56.rounded-2xl.shadow-2xl.bg-white.ring-1.z-50.origin-top-right.overflow-hidden(
              class="ring-black/5"
              x-show="langOpen"
              @click.away="langOpen = false"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 scale-100"
              x-transition:leave-end="opacity-0 scale-95"
              style="display: none;"
            )
              .py-2
                each name, code in locales
                  a(
                    href="?locale=" + code + "&" + queryString
                    class="flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition-all rounded-lg mx-1"
                  )
                    span #{flagEmoji[code] || '🌐'}
                    | #{name}
                    if code === currentLocale
                      span.ml-auto.text-indigo-600 ✓

          .w-px.bg-indigo-200.my-2

          .relative
            button(
              @click="mainOpen = !mainOpen"
              class="inline-flex items-center gap-2 px-5 py-2 text-sm font-semibold text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition-all rounded-r-full"
            )
              span 🍔 Menu
              span.text-xs.transition-transform.duration-200(:class="{ 'rotate-180': mainOpen }") ▼

            .absolute.right-0.mt-3.w-64.rounded-2xl.shadow-2xl.bg-white.ring-1.z-50.origin-top-right.overflow-hidden(
              class="ring-black/5"
              x-show="mainOpen"
              @click.away="mainOpen = false"
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100 scale-100"
              x-transition:leave-end="opacity-0 scale-95"
              style="display: none;"
            )
              .py-2.max-h-80.overflow-y-auto
                each link in links
                  if link.children && link.children.length
                    .relative(x-data="{ subOpen: false }")
                      button(
                        @click="subOpen = !subOpen"
                        class="w-full flex items-center justify-between px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-indigo-50 hover:text-indigo-700"
                      )
                        span.flex.items-center.gap-2 📁 #{link.name}
                        span.text-xs.transition-transform.duration-200(:class="{ 'rotate-180': subOpen }") ▼
                      .bg-gray-50.border-l-2.border-indigo-200.ml-2(
                        x-show="subOpen"
                        @click.away="subOpen = false"
                      )
                        each child in link.children
                          a(
                            href=child.url
                            class="block pl-8 pr-5 py-2 text-sm text-gray-600 hover:bg-indigo-100 hover:text-indigo-700"
                          )
                            span.flex.items-center.gap-2 🔹 #{child.name}
                  else
                    a(
                      href=link.url
                      class="flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 rounded-lg mx-1"
                    ) 🍖 #{link.name}

      .md-hidden.flex.items-center
        button(
          @click="mobileOpen = !mobileOpen"
          class="inline-flex items-center justify-center p-2 rounded-xl text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition"
        )
          span.text-2xl(x-show="!mobileOpen") ☰
          span.text-2xl(x-show="mobileOpen") ✕

    .md-hidden.pb-4.pt-2.border-t.border-gray-200.bg-white.rounded-b-2xl.shadow-2xl.backdrop-blur-sm(
      x-show="mobileOpen"
      @click.away="mobileOpen = false"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 -translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-4"
      style="display: none;"
    )
      .space-y-1
        .px-4.py-2.border-b.border-gray-100
          .text-xs.font-semibold.text-gray-400.uppercase.tracking-wider.mb-2 🌐 Language
          each name, code in locales
            a(
              href="?locale=" + code + "&" + queryString
              class="flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-indigo-50 rounded-lg transition-all"
            )
              span #{flagEmoji[code] || '🌐'}
              | #{name}
              if code === currentLocale
                span.ml-auto.text-indigo-600 ✓

        each link in links
          if link.children && link.children.length
            .rounded-xl.overflow-hidden(x-data="{ subOpen: false }")
              button(
                @click="subOpen = !subOpen"
                class="w-full flex items-center justify-between px-4 py-3 text-base font-semibold text-gray-700 hover:bg-indigo-50"
              )
                span.flex.items-center.gap-2 📂 #{link.name}
                span.text-xs.transition-transform.duration-200(:class="{ 'rotate-180': subOpen }") ▼
              .bg-gray-50.rounded-lg.mx-2.mb-1(
                x-show="subOpen"
                x-collapse.duration.300ms
              )
                each child in link.children
                  a(
                    href=child.url
                    class="block pl-8 pr-4 py-2.5 text-sm text-gray-600 hover:bg-indigo-100"
                  )
                    span.flex.items-center.gap-2 🔹 #{child.name}
          else
            a(
              href=link.url
              class="flex items-center gap-3 px-4 py-3 text-base font-semibold text-gray-700 hover:bg-indigo-50 rounded-xl"
            ) 🍖 #{link.name}
