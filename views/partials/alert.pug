if message
  .flex.items-center.gap-3.bg-emerald-50.border.border-emerald-200.text-emerald-800.px-5.py-4.rounded-xl.shadow-sm.mx-6.mt-2(role="alert")
    span.text-xl ✅
    span.font-medium #{message}

if error
  .flex.items-center.gap-3.bg-red-50.border.border-red-200.text-red-800.px-5.py-4.rounded-xl.shadow-sm.mx-6.mt-2(role="alert")
    span.text-xl ❌
    span.font-medium #{error}
